<%- include('partials/header', { page: 'appointment', title: 'Book Appointment' }) %>

<div class="page-hero">
  <h1>Book Appointment</h1>
  <p class="hindi">अपॉइंटमेंट बुक करें</p>
</div>

<section class="section">
  <div class="section-inner">
    <% if (typeof success !== 'undefined' && success) { %>
    <div class="flash-message flash-success" style="max-width:600px;margin:0 auto 24px;text-align:center">
      ✅ Appointment booked successfully! We'll call you on <strong><%= success.phone %></strong> to confirm. Your booking ID: <strong><%= success.id %></strong>
    </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="flash-message flash-error" style="max-width:600px;margin:0 auto 24px;text-align:center"><%= error %></div>
    <% } %>

    <div class="appt-wrap">
      <div class="appt-info">
        <h2>Schedule Your Test</h2>
        <p class="hi hindi">अपनी सुविधानुसार टेस्ट बुक करें</p>
        <p style="color:var(--slate);line-height:1.8;font-size:0.95rem">
          Fill in the form and our team will confirm your appointment. You can also walk in directly at our centre.
        </p>
        <div class="appt-features">
          <div class="appt-feature">
            <div class="appt-feature-icon">
              <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <div class="appt-feature-text">
              <h4>Home Sample Collection</h4>
              <p class="hindi" style="font-size:0.82rem;color:var(--slate)">घर पर सैंपल कलेक्शन उपलब्ध</p>
              <p>Our phlebotomist comes to your doorstep at your preferred time.</p>
            </div>
          </div>
          <div class="appt-feature">
            <div class="appt-feature-icon">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="appt-feature-text">
              <h4>Fast Results</h4>
              <p class="hindi" style="font-size:0.82rem;color:var(--slate)">15 मिनट से 24 घंटे में रिपोर्ट</p>
              <p>Most results ready within 2–4 hours. Same-day reports for urgent tests.</p>
            </div>
          </div>
          <div class="appt-feature">
            <div class="appt-feature-icon">
              <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 1.2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="appt-feature-text">
              <h4>WhatsApp Reports</h4>
              <p class="hindi" style="font-size:0.82rem;color:var(--slate)">व्हाट्सएप पर रिपोर्ट मिलेगी</p>
              <p>Reports sent directly to your WhatsApp. Also downloadable online.</p>
            </div>
          </div>
          <div class="appt-feature">
            <div class="appt-feature-icon">
              <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <div class="appt-feature-text">
              <h4>Affordable Prices</h4>
              <p class="hindi" style="font-size:0.82rem;color:var(--slate)">किफायती दाम</p>
              <p>Competitive pricing. Discounts available on health packages.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="appt-form">
        <h3 style="font-family:var(--font-display);font-weight:700;font-size:1.2rem;margin-bottom:24px;color:var(--ink)">
          Appointment Details
        </h3>
        <form method="POST" action="/appointment">
          <div class="form-row">
            <div class="form-group">
              <label>Full Name <span class="hi">नाम</span></label>
              <input type="text" name="name" class="form-control" placeholder="Your full name" required />
            </div>
            <div class="form-group">
              <label>Age / Sex <span class="hi">उम्र / लिंग</span></label>
              <input type="text" name="ageSex" class="form-control" placeholder="e.g. 35 / Male" required />
            </div>
          </div>
          <div class="form-group">
            <label>Phone Number <span class="hi">फ़ोन नंबर</span></label>
            <input type="tel" name="phone" class="form-control" placeholder="10-digit mobile number" required pattern="[0-9]{10}" />
          </div>
          <div class="form-group">
            <label>Address <span class="hi">पता</span></label>
            <input type="text" name="address" class="form-control" placeholder="Village / Town, District" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Preferred Date <span class="hi">तारीख</span></label>
              <input type="date" name="date" class="form-control" required min="<%= new Date().toISOString().split('T')[0] %>" />
            </div>
            <div class="form-group">
              <label>Preferred Time <span class="hi">समय</span></label>
              <select name="time" class="form-control" required>
                <option value="">Select time slot</option>
                <option>7:00 AM – 9:00 AM</option>
                <option>9:00 AM – 11:00 AM</option>
                <option>11:00 AM – 1:00 PM</option>
                <option>1:00 PM – 3:00 PM</option>
                <option>3:00 PM – 5:00 PM</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>Service Type <span class="hi">सेवा का प्रकार</span></label>
            <select name="serviceType" class="form-control" required>
              <option value="">Select service</option>
              <option value="walkin">Walk-in at Centre</option>
              <option value="home">Home Sample Collection</option>
            </select>
          </div>
          <div class="form-group">
            <label>Tests Required <span class="hi">जांच</span></label>
            <textarea name="tests" class="form-control" placeholder="e.g. CBC, Thyroid, Dengue... or describe symptoms"></textarea>
          </div>
          <div class="form-group">
            <label>Referred by Doctor / ASHA <span class="hi">डॉक्टर का नाम</span></label>
            <input type="text" name="referredBy" class="form-control" placeholder="Doctor / ASHA worker name (optional)" />
          </div>
          <button type="submit" class="btn btn-primary btn-full">
            <svg viewBox="0 0 24 24" width="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Confirm Appointment
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
