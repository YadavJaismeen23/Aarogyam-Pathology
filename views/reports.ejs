<%- include('partials/header', { page: 'reports', title: 'Download Report' }) %>

<div class="page-hero">
  <h1>Download Your Report</h1>
  <p class="hindi">अपनी रिपोर्ट डाउनलोड करें</p>
</div>

<section class="section">
  <div class="section-inner">
    <div class="report-lookup">
      <h2>Enter Your Details</h2>
      <p class="hindi" style="color:var(--slate);margin-bottom:28px">अपना मोबाइल नंबर या Patient ID दर्ज करें</p>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="flash-message flash-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/reports/search" style="margin-bottom:24px">
        <div class="report-lookup-form">
          <input type="text" name="query" class="form-control" placeholder="Mobile number or Patient ID" required value="<%= typeof query !== 'undefined' ? query : '' %>" />
          <button type="submit" class="btn btn-primary">Search</button>
        </div>
      </form>

      <% if (typeof reports !== 'undefined' && reports.length > 0) { %>
        <div style="margin-top:32px;text-align:left">
          <h3 style="font-family:var(--font-display);font-size:1rem;font-weight:700;margin-bottom:16px">Found <%= reports.length %> report(s)</h3>
          <% reports.forEach(r => { %>
          <div style="background:var(--mist);border:1px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
            <div>
              <div style="font-weight:600;font-size:0.95rem"><%= r.patientName %></div>
              <div style="font-size:0.8rem;color:var(--slate)"><%= r.testName %> · <%= new Date(r.uploadedAt).toLocaleDateString('en-IN') %></div>
              <div style="font-size:0.75rem;color:var(--slate)">ID: <%= r.id %></div>
            </div>
            <a href="/reports/download/<%= r.id %>" class="btn btn-primary btn-sm" download>
              <svg viewBox="0 0 24 24" width="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download PDF
            </a>
          </div>
          <% }) %>
        </div>
      <% } else if (typeof reports !== 'undefined' && reports.length === 0) { %>
        <div class="flash-message flash-error">No reports found for this number. Contact: 9821220304</div>
      <% } %>

      <div style="margin-top:24px;padding-top:24px;border-top:1px solid var(--border);font-size:0.85rem;color:var(--slate)">
        Report not found? Call us or WhatsApp on <strong>9821220304</strong>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
